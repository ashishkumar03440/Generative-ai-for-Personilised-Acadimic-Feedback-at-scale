# ── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── JWT Secrets ───────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# ── JWT Expiry ────────────────────────────────────────────────────────────────
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Cookie ────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
COOKIE_SECRET=

# ── Email (Nodemailer / Gmail) ───────────────────────────────────────────────
# Use a Gmail App Password: https://myaccount.google.com/apppasswords
EMAIL_USER=
EMAIL_PASS=

# ── Frontend URL (used for CORS and reset email links) ────────────────────────
FRONTEND_URL=https://your-frontend-url.vercel.app

# ── AI / External APIs ────────────────────────────────────────────────────────
GEMINI_API_KEY=
GOOGLE_API_KEY=
# PINECONE_API_KEY=
# PINECONE_INDEX_NAME=

# ── Google OAuth 2.0 ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://your-backend-url.onrender.com/user/auth/google/callback
